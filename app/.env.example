# Network: 'mainnet' for Base mainnet, anything else (or unset) for Base Sepolia.
ENIGMA_NETWORK=sepolia

# Custom RPC override. If unset, defaults to https://sepolia.base.org or https://mainnet.base.org.
RPC_URL=

# WalletConnect v2 project ID — get one at https://cloud.walletconnect.com
WALLETCONNECT_PROJECT_ID=

# Pinata IPFS pinning — get JWT at https://app.pinata.cloud/developers/api-keys
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud

# The Graph subgraph for Enigma (deploy via subgraph/ once it exists).
SUBGRAPH_URL=https://api.thegraph.com/subgraphs/name/enigma/base-sepolia

# Deployed contract addresses (filled in after running contracts/script/Deploy.s.sol).
ORG_FACTORY_ADDRESS=
RECOVERY_REGISTRY_ADDRESS=
PAYMASTER_ADDRESS=

# Signer service URL for ERC-4337 paymaster sponsorship handshake (plan 04-03).
SIGNER_SERVICE_URL=

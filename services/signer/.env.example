# Hex private key of the policySigner. Set on the paymaster via setPolicySigner.
POLICY_SIGNER_PRIVATE_KEY=0x

# Deployed Paymaster address.
PAYMASTER_ADDRESS=0x

# Base mainnet (8453) or Base Sepolia (84532).
CHAIN_ID=84532

# Public RPC for sanity-checks against MembershipNFT.memberSince and the paymaster itself.
RPC_URL=https://sepolia.base.org

# Subgraph endpoint (returns trusted Governor + MembershipNFT addresses per org).
SUBGRAPH_URL=

# Comma-separated lowercase function selectors we will sponsor. Bypasses subgraph
# allowlist check for these selectors; subgraph still validates target identity.
ALLOWED_SELECTORS=0x56781388,0xeb9019d4,0xb4220d04,0xc4d66de8,0x5c19a95c

# Validity window for issued signatures, in seconds. Default 300.
VALIDITY_WINDOW_SECONDS=300

# HTTP port.
PORT=8787
